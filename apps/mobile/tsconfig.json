{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "@mackaye/domain": ["../../packages/domain/src"],
      "@mackaye/content-schema": ["../../packages/content-schema/src"],
      "@mackaye/sync-core": ["../../packages/sync-core/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["src/**/__tests__/**"],
  "references": [
    { "path": "../../packages/domain" },
    { "path": "../../packages/content-schema" },
    { "path": "../../packages/sync-core" }
  ]
}
