{
  "name": "mackaye-fieldbook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace @mackaye/mobile",
    "android": "npm run android --workspace @mackaye/mobile",
    "ios": "npm run ios --workspace @mackaye/mobile",
    "web": "npm run web --workspace @mackaye/mobile",
    "export:web": "tsx scripts/build-web-companion.ts",
    "verify:web-export": "tsx scripts/verify-web-export.ts",
    "deploy:web": "tsx scripts/deploy-web-companion.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b",
    "test": "jest",
    "validate:content": "tsx scripts/validate-content.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.14",
    "fake-indexeddb": "^6.2.4",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^56.0.4",
    "expo-doctor": "1.19.10",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.53.1"
  }
}
